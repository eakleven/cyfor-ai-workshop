{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "npm run prisma:generate && npm run prisma:sync && tsx watch src/index.ts",
    "generate": "npm run prisma:generate && tsx scripts/export-openapi.ts",
    "build": "npm run prisma:generate && tsx scripts/export-openapi.ts && tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:sync": "prisma db push --skip-generate",
    "start": "npm run prisma:generate && npm run prisma:sync && node dist/src/index.js",
    "test": "vitest run"
  },
  "vitest": {
    "environment": "node"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^0.19.10",
    "@prisma/client": "^6.16.2",
    "hono": "^4.12.14",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "prisma": "^6.16.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
