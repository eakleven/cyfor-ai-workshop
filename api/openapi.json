{
  "openapi": "3.0.0",
  "info": {
    "title": "Cyfor Workshop API",
    "version": "1.0.0",
    "description": "Workshop starter API built with Hono, Prisma, and SQLite."
  },
  "components": {
    "schemas": {
      "RootResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "openapi": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "openapi"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Meeting Room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Seats 10, projector included"
          },
          "type": {
            "type": "string",
            "enum": [
              "Room",
              "Equipment",
              "Vehicle",
              "Other"
            ],
            "example": "Room"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "type",
          "createdAt"
        ]
      },
      "ItemListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "CreateItem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Meeting Room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "default": "",
            "example": "Seats 10, projector included"
          },
          "type": {
            "type": "string",
            "enum": [
              "Room",
              "Equipment",
              "Vehicle",
              "Other"
            ],
            "default": "Other",
            "example": "Room"
          }
        },
        "required": [
          "title"
        ]
      },
      "NotFound": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "UpdateItem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Meeting Room A"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "example": "Seats 10, projector included"
          },
          "type": {
            "type": "string",
            "enum": [
              "Room",
              "Equipment",
              "Vehicle",
              "Other"
            ],
            "example": "Room"
          }
        }
      },
      "ReservationStatus": {
        "type": "string",
        "enum": [
          "Draft",
          "Confirmed",
          "Cancelled",
          "Completed"
        ],
        "example": "Confirmed"
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "itemId": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 1
          },
          "startAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T09:00:00.000Z"
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00.000Z"
          },
          "reserverName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Ola Nordmann"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "example": "Planleggingsmote"
          },
          "status": {
            "$ref": "#/components/schemas/ReservationStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T08:30:00.000Z"
          }
        },
        "required": [
          "id",
          "itemId",
          "startAt",
          "endAt",
          "reserverName",
          "purpose",
          "status",
          "createdAt"
        ]
      },
      "ReservationListResponse": {
        "type": "object",
        "properties": {
          "reservations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reservation"
            }
          }
        },
        "required": [
          "reservations"
        ]
      },
      "Conflict": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "CreateReservation": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 1
          },
          "startAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T09:00:00.000Z"
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00.000Z"
          },
          "reserverName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Ola Nordmann"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "example": "Planleggingsmote"
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ReservationStatus"
              },
              {
                "default": "Draft",
                "example": "Draft"
              }
            ]
          }
        },
        "required": [
          "itemId",
          "startAt",
          "endAt",
          "reserverName",
          "purpose"
        ]
      },
      "BadRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "UpdateReservation": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 1
          },
          "startAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T09:00:00.000Z"
          },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00.000Z"
          },
          "reserverName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "example": "Ola Nordmann"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "example": "Planleggingsmote"
          },
          "status": {
            "$ref": "#/components/schemas/ReservationStatus"
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Basic API information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "Meeting Room"
            },
            "required": false,
            "name": "search",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "Room",
                "Equipment",
                "Vehicle",
                "Other"
              ],
              "example": "Room"
            },
            "required": false,
            "name": "type",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List persisted items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Items"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItem"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a persisted item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "delete": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Remove a persisted item"
          }
        }
      },
      "patch": {
        "tags": [
          "Items"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateItem"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update a persisted resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          }
        }
      }
    },
    "/reservations": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": false,
            "name": "itemId",
            "in": "query"
          },
          {
            "schema": {
              "$ref": "#/components/schemas/ReservationStatus"
            },
            "required": false,
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2024-01-01T09:00:00.000Z"
            },
            "required": false,
            "name": "from",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2024-01-01T10:00:00.000Z"
            },
            "required": false,
            "name": "to",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List persisted reservations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Reservations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Create a reservation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          },
          "409": {
            "description": "Reservation conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conflict"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{id}": {
      "patch": {
        "tags": [
          "Reservations"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "example": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateReservation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update a reservation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reservation"
                }
              }
            }
          },
          "400": {
            "description": "Invalid reservation data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              }
            }
          },
          "404": {
            "description": "Reservation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          },
          "409": {
            "description": "Reservation conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conflict"
                }
              }
            }
          }
        }
      }
    }
  }
}
